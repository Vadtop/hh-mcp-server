# === HH.ru OAuth 2.0 ===
# Получите на https://dev.hh.ru после регистрации приложения
HH_CLIENT_ID=your_client_id
HH_CLIENT_SECRET=your_client_secret
HH_REDIRECT_URI=https://localhost/callback

# Токены (заполняются после OAuth flow)
HH_ACCESS_TOKEN=
HH_REFRESH_TOKEN=

# User-Agent (обязателен, укажите ваш email)
HH_USER_AGENT=HH MCP Server/1.0 (your_email@example.com)

# App Token (для авторизации приложения)
HH_APP_TOKEN=

# === Rate Limiting ===
HH_RATE_LIMIT_REQUESTS=100
HH_RATE_LIMIT_PERIOD=60

# === Cache ===
CACHE_TTL=300
CACHE_ENABLED=true

# === AI Configuration (OpenRouter) ===
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_key_here
# Модели (выбрать одну):
# google/gemini-2.5-flash      — дёшево, быстро (рекомендуется)
# anthropic/claude-3-haiku     — качественно
# meta-llama/llama-3.1-8b-instruct:free — бесплатно
AI_MODEL=google/gemini-2.5-flash
AI_TEMPERATURE=0.7

# === My Profile (для персональных писем и скоринга) ===
MY_NAME=Вадим
MY_GITHUB=github.com/Vadtop
MY_TELEGRAM=@vadimka163
MY_EXPECTED_SALARY=100000
MY_WORK_FORMAT=удалённо, по всей России
# Текст резюме для промпта LLM (одна строка)
MY_RESUME_TEXT=AI Integration Engineer. RAG-системы, LLM-агенты, автоматизация на n8n. Проекты: RAG-агент в продакшне (rag-from-scratch-production.up.railway.app/chat), многоагентная система 50+ инструментов, MCP сервер для hh.ru. Стек: Python, FastAPI, LangChain, ChromaDB, n8n, OpenAI/Claude/DeepSeek, Docker, Playwright, MCP.
# Навыки через запятую (для скоринга)
MY_SKILLS=python,fastapi,langchain,chromadb,n8n,openai,claude,deepseek,docker,playwright,rag,llm,mcp,multi-agent

# Скоринг
SCORING_THRESHOLD=60

# === Monitoring ===
MONITOR_INTERVAL=300
MONITOR_ENABLED=true

# === Notifications ===
NOTIFY_TELEGRAM=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=hh_mcp.log
