# === HH.ru OAuth 2.0 ===
# Получите на https://dev.hh.ru после регистрации приложения
HH_CLIENT_ID=your_client_id
HH_CLIENT_SECRET=your_client_secret
HH_REDIRECT_URI=https://localhost/callback

# Токены (заполняются после OAuth flow)
HH_ACCESS_TOKEN=
HH_REFRESH_TOKEN=

# User-Agent (обязателен, укажите ваш email)
HH_USER_AGENT=HH MCP Server/1.0 (your_email@example.com)

# App Token (для авторизации приложения)
HH_APP_TOKEN=

# === Rate Limiting ===
HH_RATE_LIMIT_REQUESTS=100
HH_RATE_LIMIT_PERIOD=60

# === Cache ===
CACHE_TTL=300
CACHE_ENABLED=true

# === AI Configuration (Optional) ===
# Для генерации сопроводительных писем
OPENAI_API_KEY=sk-your_openai_key
AI_MODEL=gpt-3.5-turbo
AI_TEMPERATURE=0.7

# Скоринг
SCORING_THRESHOLD=60

# === Monitoring ===
MONITOR_INTERVAL=300
MONITOR_ENABLED=true

# === Notifications ===
NOTIFY_TELEGRAM=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=hh_mcp.log
